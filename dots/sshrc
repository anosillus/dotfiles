# set filetype=bash
# ~/.sshrc

# Alias
alias quit='exit'
alias cls='reset'

# Function
function mkcd() {
  mkdir $* && \cd $_ && ls
}

# ls
alias la='ls -a'
alias ll='ls -l'
alias lal='ls -la'
alias lla='ls -la'
alias la1='ls -a -1'
alias ls1='ls -1'

# cd
alias ..='cdd ..'
alias ...='cdd ../..'
alias -- -='cd - && ls'
alias -- --='cd - && ls'

# grep
alias grep='grep --color'
alias grepinr='grep -inR'
